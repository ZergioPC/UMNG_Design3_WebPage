---
import Button from './Button.astro';
import { newsletter } from '@/data/siteConfig';

const { title, subtitle, placeholder, ctaText } = newsletter;
---

<section class="newsletter">
  <div class="container">
    <div class="newsletter__content">
      <h2 class="newsletter__title">{title}</h2>
      <p class="newsletter__subtitle">{subtitle}</p>
      <form class="newsletter__form" action="#" method="POST">
        <div class="newsletter__input-wrapper">
          <label for="email" class="sr-only">Correo electrónico</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder={placeholder}
            required
            class="newsletter__input"
          />
        </div>
        <Button type="submit" variant="primary">{ctaText}</Button>
      </form>
    </div>
  </div>
</section>

<style>
  .newsletter {
    padding-block: var(--space-16);
    background-color: var(--color-secondary-dark);
  }

  .newsletter__content {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .newsletter__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-primary-dark);
    margin-bottom: var(--space-4);
  }

  .newsletter__subtitle {
    font-size: var(--text-base);
    color: var(--color-primary);
    margin-bottom: var(--space-8);
    opacity: 0.9;
  }

  .newsletter__form {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  .newsletter__input-wrapper {
    flex: 1;
    min-width: 280px;
  }

  .newsletter__input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-ebony);
    background-color: var(--color-smoke-white);
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    transition: border-color 0.2s ease;
  }

  .newsletter__input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter__input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .newsletter__form {
      flex-direction: column;
    }

    .newsletter__input-wrapper {
      min-width: 100%;
    }
  }
</style>
