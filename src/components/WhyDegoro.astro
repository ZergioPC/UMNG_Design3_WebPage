---
import { pillars } from '@/data/siteConfig';

const icons: Record<string, string> = {
  hands: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>`,
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  heart: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`
};
---

<section class="why-degoro">
  <div class="container">
    <header class="why-degoro__header">
      <h2 class="why-degoro__title">¿Por qué Degoro?</h2>
    </header>
    <div class="why-degoro__grid">
      {pillars.map((pillar) => (
        <article class="why-degoro__pillar">
          <div class="why-degoro__icon" set:html={icons[pillar.icon]} />
          <h3 class="why-degoro__pillar-title">{pillar.title}</h3>
          <p class="why-degoro__pillar-description">{pillar.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-degoro {
    padding-block: var(--space-16);
    background-color: var(--color-bg-alt);
  }

  .why-degoro__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .why-degoro__title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-heading);
  }

  .why-degoro__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .why-degoro__pillar {
    text-align: center;
    padding: var(--space-8);
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .why-degoro__pillar:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .why-degoro__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    background-color: var(--color-secondary-light);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .why-degoro__pillar-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-heading);
    margin-bottom: var(--space-4);
  }

  .why-degoro__pillar-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .why-degoro__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .why-degoro__title {
      font-size: var(--text-2xl);
    }
  }
</style>
