---
import Button from './Button.astro';
import { heroData } from '@/data/siteConfig';

const { tagline, subtitle, ctaText, ctaHref, backgroundImage } = heroData;
---

<section class="hero">
  <div class="hero__background">
    <img
      src={backgroundImage}
      alt="Artesano tejiendo tradicional textoil"
      class="hero__image"
      loading="eager"
    />
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__content container">
    <h1 class="hero__tagline">{tagline}</h1>
    <p class="hero__subtitle">{subtitle}</p>
    <Button href={ctaHref} variant="primary">{ctaText}</Button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(46, 46, 46, 0.3) 0%,
      rgba(46, 46, 46, 0.5) 50%,
      rgba(46, 46, 46, 0.7) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: var(--color-smoke-white);
    padding-block: var(--space-16);
  }

  .hero__tagline {
    font-family: var(--font-brand);
    font-size: var(--text-4xl);
    font-weight: 700;
    font-style: italic;
    color: var(--color-smoke-white);
    margin-bottom: var(--space-4);
    max-width: 800px;
    margin-inline: auto;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-secondary-light);
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }

    .hero__tagline {
      font-size: var(--text-3xl);
    }
  }
</style>
