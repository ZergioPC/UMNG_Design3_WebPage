---
const title = 'Nuestra Historia'
const description = 'Degoro nació del deseo de conectar a las comunidades artesanales colombianas con personas que valoran la autenticidad y la historia detrás de cada prenda. Cada pieza que creamos es un puente entre la tradición y la moda contemporánea.'

const images = [
  {
    src: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800',
    alt: 'Artesana tejiendo en un telar tradicional'
  },
  {
    src: 'https://images.unsplash.com/photo-1605000797499-95a51c5269ae?w=800',
    alt: 'Primer plano de textiles artesanales coloridos'
  },
  {
    src: 'https://images.unsplash.com/photo-1547036967-23d11aacaee0?w=800',
    alt: 'Prendas hechas a mano con fibras naturales'
  }
]
---

<section class="brand-story">
  <div class="container">
    <div class="brand-story__grid">
      <div class="brand-story__images">
        {images.map((img) => (
          <div class="brand-story__image-wrapper">
            <img src={img.src} alt={img.alt} class="brand-story__image" loading="lazy" />
          </div>
        ))}
      </div>
      <div class="brand-story__content">
        <h2 class="brand-story__title">{title}</h2>
        <p class="brand-story__description">{description}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .brand-story {
    background-color: var(--color-primary);
    padding-block: var(--space-16);
  }

  .brand-story__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .brand-story__images {
    display: flex;
    gap: var(--space-4);
    height: 400px;
  }

  .brand-story__image-wrapper {
    flex-grow: 1;
    flex-basis: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transition: flex-grow 0.4s ease;
    cursor: pointer;
  }

  .brand-story__images:hover .brand-story__image-wrapper {
    flex-grow: 0.3;
  }

  .brand-story__images .brand-story__image-wrapper:hover {
    flex-grow: 2;
  }

  .brand-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-story__content {
    color: var(--color-smoke-white);
  }

  .brand-story__title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-secondary-light);
    margin-bottom: var(--space-6);
  }

  .brand-story__description {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-secondary-light);
    opacity: 0.9;
  }

  @media (max-width: 900px) {
    .brand-story__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .brand-story__images {
      height: 250px;
    }

    .brand-story__title {
      font-size: var(--text-2xl);
    }
  }
</style>
